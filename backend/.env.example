# Database — provided automatically by Railway PostgreSQL plugin
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB"

# JWT — generate a strong secret: openssl rand -hex 64
JWT_SECRET="change-me-to-a-strong-random-secret"
JWT_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV="production"

# Frontend URL — set to your Vercel deployment URL
FRONTEND_URL="https://your-app.vercel.app"

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS="https://your-app.vercel.app"

# Google OAuth — for Google Sheets sync
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-secret"
# Must match Railway backend URL + /auth/google/callback
GOOGLE_REDIRECT_URI="https://your-backend.railway.app/auth/google/callback"

# Mail (SMTP) — leave MAIL_HOST empty to disable email notifications
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER="your-email@gmail.com"
MAIL_PASS="your-app-password"
MAIL_FROM="your-email@gmail.com"
