{
  "redirects": [
    {
      "source": "/api-proxy/auth/google",
      "destination": "https://tourneepro-production.up.railway.app/auth/google",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api-proxy/:path*", "destination": "https://tourneepro-production.up.railway.app/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
